---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { servidor } from '../config/servidor';
import { variablesTema, estiloInline } from '../lib/tokens';
import { tieneLogo, tieneImagenHero } from '../lib/fallbacks';
import { validarColores } from '../lib/colores';
import { redesActivas } from '../lib/redes';
import Redes from '../components/Redes.astro';

interface Props {
  titulo?: string;
}
const { titulo } = Astro.props;

validarColores(servidor.colores);
const rootStyle = `:root{${estiloInline(variablesTema(servidor))}}`;
const tituloPagina = titulo
  ? `${titulo} · ${servidor.nombre}`
  : `${servidor.nombre} · ${servidor.lema}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImagen = tieneImagenHero(servidor)
  ? new URL(servidor.imagenHero!, Astro.site)
  : undefined;
const marca = tieneLogo(servidor) ? servidor.logo! : null;
const hayNormas = (await getCollection('normas')).length > 0;
const hayStaff = servidor.staff.length > 0;
const hayPie = redesActivas(servidor.redes).length > 0 || servidor.creditoPlantilla;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{tituloPagina}</title>
    <meta name="description" content={servidor.descripcion} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={tituloPagina} />
    <meta property="og:description" content={servidor.descripcion} />
    <meta property="og:url" content={canonical} />
    {ogImagen && <meta property="og:image" content={ogImagen} />}
    <meta name="theme-color" content={servidor.colores.fondo} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" href="/favicon.svg" />
    <style set:html={rootStyle}></style>
  </head>
  <body>
    <header class="cabecera contenedor">
      <a class="cabecera__marca" href="/">
        {marca ? <img src={marca} alt={servidor.nombre} height="32" /> : servidor.nombre}
      </a>
      <nav class="cabecera__nav" aria-label="Principal">
        <a class="cabecera__enlace" href="/">Inicio</a>
        {hayNormas && <a class="cabecera__enlace" href="/normas/">Normas</a>}
        {hayStaff && <a class="cabecera__enlace" href="/staff/">Staff</a>}
      </nav>
      <a class="boton boton--compacto cabecera__discord" href={servidor.urlDiscord}>Discord</a>
    </header>

    <main>
      <slot />
    </main>

    {hayPie && (
      <footer class="pie contenedor">
        <Redes />
        {servidor.creditoPlantilla && (
          <p>
            Hecho con la <a href="https://vidaenleonida.com" rel="noopener">plantilla de VidaEnLeonida.com</a>
          </p>
        )}
      </footer>
    )}
  </body>
</html>
